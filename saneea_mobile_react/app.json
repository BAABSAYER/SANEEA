{
  "expo": {
    "name": "سنيع",
    "slug": "saneea-mobile",
    "scheme": "saneea",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/brand/app_icon.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.saneea.app"
    },
    "android": {
      "package": "com.saneea.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/app_icon_foreground.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-asset",
      "expo-video"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3f017957-6c12-4351-8f2e-3546ae89749d"
      }
    }
  }
}
