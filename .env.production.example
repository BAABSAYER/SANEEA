POSTGRES_DB=saneea
POSTGRES_USER=saneea_app
POSTGRES_PASSWORD=replace-with-long-random-db-password
DATABASE_URL=postgresql://saneea_app:replace-with-long-random-db-password@postgres:5432/saneea?sslmode=disable
SESSION_SECRET=replace-with-long-random-secret
JWT_SECRET=replace-with-long-random-secret
NODE_ENV=production
PORT=5000

OTP_PROVIDER=authentica
AUTHENTICA_BASE_URL=https://api.authentica.sa
AUTHENTICA_OTP_METHOD=sms
AUTHENTICA_API_KEY=replace-with-authentica-key
AUTHENTICA_APP_NAME=saneea

AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=replace-with-aws-key
AWS_SECRET_ACCESS_KEY=replace-with-aws-secret
AWS_S3_BUCKET=sanneea

WHATSAPP_PROVIDER=ultramsg
ULTRAMSG_BASE_URL=https://api.ultramsg.com/instance153350
ULTRAMSG_INSTANCE=instance153350
ULTRAMSG_TOKEN=replace-with-ultramsg-token
WHATSAPP_DEFAULT_ADMIN_ID=1

ERP_PROVIDER=hal
HAL_API_KEY=replace-with-hal-key
HAL_EXTERNAL_TENANT_ID=saneea
HAL_BASE_URL=https://your-erp-server.example.com/api/v1/integrations
